APP_NAME=MCP Evidence Recorder
ENVIRONMENT=development
TARGET_MCP_URL=http://127.0.0.1:9000/mcp
DATABASE_PATH=data/audit.sqlite3
POLICY_PATH=config/policies.json
REQUEST_TIMEOUT_SECONDS=30
MAX_BODY_BYTES=2000000

# Set these before exposing the app outside localhost.
ADMIN_TOKEN=
PROXY_TOKEN=

# Optional risk alert destination.
SLACK_WEBHOOK_URL=

# Used only by the stdio bridge.
STDIO_MCP_COMMAND=["python3", "examples/mock_stdio_mcp_server.py"]
STDIO_REQUEST_TIMEOUT_SECONDS=30

